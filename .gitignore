# -----------------------------------------------------------------------------
# Core Node / Build exclusions
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
.pnp/
.pnp.js
.cache/
.tmp/
.DS_Store

# -----------------------------------------------------------------------------
# Build tool junk
# -----------------------------------------------------------------------------
*.map
*.log
*.tsbuildinfo

# -----------------------------------------------------------------------------
# IDE / Editor files
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# -----------------------------------------------------------------------------
# OS-generated crap
# -----------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# PHPStorm / Xdebug cache
# -----------------------------------------------------------------------------
.phpunit.result.cache

# -----------------------------------------------------------------------------
# WordPress build exclusions
# -----------------------------------------------------------------------------
# Ignore build scripts you don't want in the plugin repo.
# (Optional – if you want loaders + configs in repo, remove these.)
# webpack.config.js
# webpack.mix.js
# rollup.config.js

# -----------------------------------------------------------------------------
# Dist folder (optional)
# -----------------------------------------------------------------------------
# If you compile blocks and want to commit *build* output, DO NOT ignore /build.
# Otherwise uncomment this:
# build/
